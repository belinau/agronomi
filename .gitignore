# ============================================================
# AgroNomi Pod Peripherals — Git Ignore
# ============================================================

# --- Build artifacts (PlatformIO) ---
.pio/

# --- Databases (runtime data, never commit) ---
*.db
*.db-shm
*.db-wal

# --- Identity / secrets (private keys) ---
*.identity
farm_hub.identity
gateway.identity

# --- WiFi credentials (per-device, never commit) ---
secrets.py

# --- Per-device secrets directory ---
# Contains placeholder templates (tracked) and real credentials (not tracked).
# Template files have "YourWiFi" placeholders and are added with: git add -f
m_reticulum/secrets/*/secrets.py

# --- Python bytecode ---
__pycache__/
*.pyc
*.pyo

# --- Python virtual environments ---
.venv/
venv/

# --- Reticulum storage cache (runtime) ---
.reticulum/
storage/

# --- Firmware binaries ---
*.bin
*.uf2
*.hex

# --- Logs ---
agronomi.log
*.log

# --- OS junk ---
.DS_Store
Thumbs.db

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- Sensor test/dev data ---
test_pipeline/test_farm.db*

# --- Deploy script cache (downloaded firmware releases) ---
agronomi-firmware/
.gitnexus
.claude/skills/gitnexus/
AGENTS.md
CLAUDE.md
documents/lxmf_storage/lxmf/
